# Copy this file to .env and fill in real values
# NEVER commit .env to git

ANTHROPIC_API_KEY=sk-ant-...
APIFY_API_KEY=apify_api_...

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id-here
# Path to your service account JSON file downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=/path/to/service-account.json

# Optional: override the model used for screening (default: claude-haiku-4-5-20251001)
# SCREENER_MODEL=claude-sonnet-4-6

# Webhook server (used by server.py)
WEBHOOK_SECRET=choose-a-random-secret-string
PORT=8080

# GitHub (used by prompt refiner to push updated prompts)
GITHUB_TOKEN=ghp_...   # personal access token with repo write scope
GITHUB_REPO=20at20/rv-deals-screener
